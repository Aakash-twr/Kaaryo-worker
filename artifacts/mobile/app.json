{
  "expo": {
    "name": "Kaaryo Worker",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/k-worker.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/k-worker.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A3C30"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocationWhenInUseUsageDescription": "Kaaryo uses your location while you're online to match you with nearby job requests."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.akashtwr.mobile"
    },
    "web": {
      "favicon": "./assets/images/k-worker.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Kaaryo needs access to your gallery so you can upload your practical task videos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kaaryo uses your location while you're online to match you with nearby job requests."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
